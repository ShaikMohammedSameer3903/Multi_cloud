# Single-Administrator Authentication
LOCAL_ADMIN_EMAIL=admin@cloudops-local.com
LOCAL_ADMIN_PASSWORD_HASH=$2a$10$Uv0L6l4eKk52Xk52Xk52XuG/X8h9xY.Z/m/w5X5X5X5X5X5X5X5X5

# Approved Production Administrator
APPROVED_ADMIN_EMAIL=admin@yourcompany.com
APPROVED_TENANT_ID=your-entra-tenant-id

# JWT Signatures Secret
JWT_SECRET=your-super-secure-jwt-secret-key

# Production Azure SDK Credentials
AZURE_CLIENT_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_SECRET=
AZURE_SUBSCRIPTION_ID=

# Frontend Configuration (used by Vite in development)
# For production builds, create .env.production with the production API URL.
VITE_API_URL=http://localhost:3001

# Frontend Azure Credentials (required for Microsoft Entra ID login)
VITE_AZURE_CLIENT_ID=your-azure-client-id
VITE_AZURE_TENANT_ID=your-azure-tenant-id

# Google OAuth Credentials (required for Google login)
VITE_GOOGLE_CLIENT_ID=your-google-client-id
