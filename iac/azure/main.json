{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.44.1.10279",
      "templateHash": "16703754455323217545"
    },
    "description": "Azure Landing Zone Core Resources, Governance, and Tuned Monitoring for Healthcare Rollout"
  },
  "parameters": {
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]"
    },
    "environment": {
      "type": "string",
      "defaultValue": "prod"
    },
    "vaultName": {
      "type": "string",
      "defaultValue": "[format('rsv-hc-{0}-backup', parameters('environment'))]"
    },
    "keyVaultName": {
      "type": "string",
      "defaultValue": "[format('kv-hc-{0}-secrets', parameters('environment'))]"
    },
    "logAnalyticsWorkspaceName": {
      "type": "string",
      "defaultValue": "[format('law-hc-{0}-logs', parameters('environment'))]"
    }
  },
  "resources": [
    {
      "type": "Microsoft.OperationalInsights/workspaces",
      "apiVersion": "2022-10-01",
      "name": "[parameters('logAnalyticsWorkspaceName')]",
      "location": "[parameters('location')]",
      "properties": {
        "sku": {
          "name": "PerGB2018"
        },
        "retentionInDays": 365
      }
    },
    {
      "type": "Microsoft.RecoveryServices/vaults",
      "apiVersion": "2023-04-01",
      "name": "[parameters('vaultName')]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "RS0",
        "tier": "Standard"
      },
      "properties": {
        "publicNetworkAccess": "Disabled",
        "securitySettings": {
          "softDeleteSettings": {
            "softDeleteState": "Enabled"
          }
        }
      }
    },
    {
      "type": "Microsoft.RecoveryServices/vaults/backupstorageconfig",
      "apiVersion": "2023-04-01",
      "name": "[format('{0}/{1}', parameters('vaultName'), 'vaultstorageconfig')]",
      "properties": {
        "storageModelType": "GeoRedundant",
        "crossRegionRestoreFlag": true
      },
      "dependsOn": [
        "[resourceId('Microsoft.RecoveryServices/vaults', parameters('vaultName'))]"
      ]
    },
    {
      "type": "Microsoft.KeyVault/vaults",
      "apiVersion": "2023-02-01",
      "name": "[parameters('keyVaultName')]",
      "location": "[parameters('location')]",
      "properties": {
        "sku": {
          "family": "A",
          "name": "premium"
        },
        "tenantId": "[subscription().tenantId]",
        "enableSoftDelete": true,
        "softDeleteRetentionInDays": 90,
        "enablePurgeProtection": true,
        "enableRbacAuthorization": true,
        "networkAcls": {
          "bypass": "AzureServices",
          "defaultAction": "Deny",
          "ipRules": [],
          "virtualNetworkRules": []
        }
      }
    },
    {
      "type": "Microsoft.Insights/diagnosticSettings",
      "apiVersion": "2021-05-01-preview",
      "scope": "[resourceId('Microsoft.KeyVault/vaults', parameters('keyVaultName'))]",
      "name": "kv-audit-logs",
      "properties": {
        "workspaceId": "[resourceId('Microsoft.OperationalInsights/workspaces', parameters('logAnalyticsWorkspaceName'))]",
        "logs": [
          {
            "category": "AuditEvent",
            "enabled": true,
            "retentionPolicy": {
              "days": 365,
              "enabled": true
            }
          }
        ],
        "metrics": [
          {
            "category": "AllMetrics",
            "enabled": true,
            "retentionPolicy": {
              "days": 365,
              "enabled": true
            }
          }
        ]
      },
      "dependsOn": [
        "[resourceId('Microsoft.KeyVault/vaults', parameters('keyVaultName'))]",
        "[resourceId('Microsoft.OperationalInsights/workspaces', parameters('logAnalyticsWorkspaceName'))]"
      ]
    },
    {
      "type": "Microsoft.Insights/metricAlerts",
      "apiVersion": "2018-03-01",
      "name": "alert-hc-backup-failures",
      "location": "global",
      "properties": {
        "description": "Alert on consecutive backup job failures. Redesigned to minimize alert noise caused by transient network glitches.",
        "severity": 1,
        "enabled": true,
        "scopes": [
          "[resourceId('Microsoft.RecoveryServices/vaults', parameters('vaultName'))]"
        ],
        "evaluationFrequency": "PT15M",
        "windowSize": "PT1H",
        "criteria": {
          "odata.type": "Microsoft.Azure.Monitor.SingleResourceMultipleMetricCriteria",
          "allOf": [
            {
              "name": "BackupFailureMetric",
              "metricName": "BackupFailureCount",
              "operator": "GreaterThanOrEqual",
              "threshold": 2,
              "timeAggregation": "Total",
              "criterionType": "StaticThresholdCriterion"
            }
          ]
        },
        "actions": []
      },
      "dependsOn": [
        "[resourceId('Microsoft.RecoveryServices/vaults', parameters('vaultName'))]"
      ]
    },
    {
      "type": "Microsoft.Insights/metricAlerts",
      "apiVersion": "2018-03-01",
      "name": "alert-hc-db-high-cpu",
      "location": "global",
      "properties": {
        "description": "Tuned DB CPU usage alert (Dynamic thresholds to accommodate daily patient intake spikes).",
        "severity": 2,
        "enabled": true,
        "scopes": [
          "[resourceId('Microsoft.RecoveryServices/vaults', parameters('vaultName'))]"
        ],
        "evaluationFrequency": "PT5M",
        "windowSize": "PT15M",
        "criteria": {
          "odata.type": "Microsoft.Azure.Monitor.SingleResourceMultipleMetricCriteria",
          "allOf": [
            {
              "name": "CpuUsageMetric",
              "metricName": "CpuPercentage",
              "operator": "GreaterThan",
              "threshold": 85,
              "timeAggregation": "Average",
              "criterionType": "StaticThresholdCriterion"
            }
          ]
        },
        "actions": []
      },
      "dependsOn": [
        "[resourceId('Microsoft.RecoveryServices/vaults', parameters('vaultName'))]"
      ]
    }
  ],
  "outputs": {
    "vaultId": {
      "type": "string",
      "value": "[resourceId('Microsoft.RecoveryServices/vaults', parameters('vaultName'))]"
    },
    "keyVaultUri": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.KeyVault/vaults', parameters('keyVaultName')), '2023-02-01').vaultUri]"
    },
    "logAnalyticsWorkspaceId": {
      "type": "string",
      "value": "[resourceId('Microsoft.OperationalInsights/workspaces', parameters('logAnalyticsWorkspaceName'))]"
    }
  }
}